# PATCH CONTEXT
# Two hunks:
#
# 1) REANodesManager.mm — opt into ProMotion's variable refresh
#    rate on iOS 15+ via `preferredFrameRateRange = (80, 120, 120)`
#    instead of `preferredFramesPerSecond = 120`. Without this,
#    iOS clamps to 60 fps on devices without ProMotion and never
#    targets 120 fps on devices that have it.
#    Carried over from the previous 3.19.4 patch.
#    Upstream Issue: none filed yet.
#    Remove when: upstream adopts a ProMotion-aware default.
#
# 2) colors.ts — null-guard `processColorsInProps` so passing a
#    `null` / `undefined` color (e.g. from a conditional animated
#    color) doesn't crash the worklet. Not upstreamed; not present
#    on latest 4.x stable or 4.4 nightly as of bump time.
#    Upstream Issue: none filed yet.
#    Linear Issue: TBD.
#    Remove when: upstream guards against null in
#    `processColorsInProps` (consider filing a PR).

diff --git a/node_modules/react-native-reanimated/apple/reanimated/apple/REANodesManager.mm b/node_modules/react-native-reanimated/apple/reanimated/apple/REANodesManager.mm
index 4138429..eb65bbd 100644
--- a/node_modules/react-native-reanimated/apple/reanimated/apple/REANodesManager.mm
+++ b/node_modules/react-native-reanimated/apple/reanimated/apple/REANodesManager.mm
@@ -28,7 +28,11 @@ - (READisplayLink *)getDisplayLink
   if (!_displayLink) {
     _displayLink = [READisplayLink displayLinkWithTarget:self selector:@selector(onAnimationFrame:)];
 #if !TARGET_OS_OSX
-    _displayLink.preferredFramesPerSecond = 120; // will fallback to 60 fps for devices without Pro Motion display
+    if (@available(iOS 15.0, *)) {
+      _displayLink.preferredFrameRateRange = CAFrameRateRangeMake(80, 120, 120);
+    } else {
+      _displayLink.preferredFramesPerSecond = 120; // will fallback to 60 fps for devices without Pro Motion display
+    }
 #endif // TARGET_OS_OSX
     [_displayLink addToRunLoop:[NSRunLoop mainRunLoop] forMode:NSRunLoopCommonModes];
   }
diff --git a/node_modules/react-native-reanimated/src/common/style/processors/colors.ts b/node_modules/react-native-reanimated/src/common/style/processors/colors.ts
index 42d2c09..974708a 100644
--- a/node_modules/react-native-reanimated/src/common/style/processors/colors.ts
+++ b/node_modules/react-native-reanimated/src/common/style/processors/colors.ts
@@ -232,6 +232,7 @@ export function processColorsInProps(props: StyleProps) {
   for (const key in props) {
     if (!ColorProperties.includes(key)) continue;
     const value = props[key];
+    if (value == null) continue;
     props[key] = Array.isArray(value)
       ? value.map((c) => processColor(c))
       : processColor(value);
