# PATCH CONTEXT
# Why: Forces continuous (squircle) corners on the Fabric renderer
#   by flipping the default `BorderCurve` resolved value from
#   Circular to Continuous in BaseViewProps. Matches iOS-system
#   rounded-rectangle styling for views that don't set an explicit
#   `borderCurve` style prop.
# Upstream Issue: none filed yet — Fabric exposes `borderCurve` as
#   a prop but the runtime default is `Circular`. Until/unless we
#   set `borderCurve: 'continuous'` everywhere in the design system,
#   patch the runtime default instead.
# Linear Issue: FEPLAT-97
# Remove when: design-system components set `borderCurve` explicitly
#   on every Box/View, or upstream changes the default.

diff --git a/node_modules/react-native/ReactCommon/react/renderer/components/view/BaseViewProps.cpp b/node_modules/react-native/ReactCommon/react/renderer/components/view/BaseViewProps.cpp
--- a/node_modules/react-native/ReactCommon/react/renderer/components/view/BaseViewProps.cpp
+++ b/node_modules/react-native/ReactCommon/react/renderer/components/view/BaseViewProps.cpp
@@ -542,7 +542,7 @@
       .borderColors = borderColors.resolve(isRTL, {}),
       .borderWidths = borderWidths.resolve(isRTL, 0),
       .borderRadii = ensureNoOverlap(radii, layoutMetrics.frame.size),
-      .borderCurves = borderCurves.resolve(isRTL, BorderCurve::Circular),
+      .borderCurves = borderCurves.resolve(isRTL, BorderCurve::Continuous),
       .borderStyles = borderStyles.resolve(isRTL, BorderStyle::Solid),
   };
 }
